{
  "name": "dice-tower",
  "version": "0.1.0",
  "description": "A modern, high-performance rewrite of Dice so Nice for FoundryVTT.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run typecheck && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:perf": "vitest run tests/performance && vitest bench --run tests/performance",
    "link:foundry": "fish ./scripts/link-foundry.fish",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --ext .ts",
    "lint:fix": "pnpm run lint -- --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "@dimforge/rapier3d": "^0.19.3",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.17.1",
    "@types/three": "^0.183.1",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.5",
    "vite-plugin-static-copy": "^4.0.1",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^4.1.3"
  }
}
